<UserControl x:Class="AIEvaluator.VSIX.Controls.AIEvaluatorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="300"
             Background="{DynamicResource VsBrush.ToolWindowBackground}"
             Foreground="{DynamicResource VsBrush.WindowText}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <!-- Header -->
            <TextBlock Text="🚀 AI Evaluator" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" />

            <!-- Setup -->
            <TextBlock Text="SETUP" FontSize="11" Opacity="0.6" Margin="0,0,0,4" />
            <Button Content="📁 Init eval project" Click="OnInitProject" Margin="0,0,0,3"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" />
            <TextBlock Text="Creates config + example dataset in your project." FontSize="10" Opacity="0.5" Margin="0,0,0,10" />

            <!-- Evaluate -->
            <TextBlock Text="EVALUATE" FontSize="11" Opacity="0.6" Margin="0,0,0,4" />
            <Button Content="▶ Quick eval (selection)" Click="OnEvaluateSelection" Margin="0,0,0,3"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" />
            <Button Content="📋 Evaluate dataset file…" Click="OnEvaluateDataset" Margin="0,0,0,3"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" />
            <TextBlock Text="Select text for quick eval, or pick a dataset file." FontSize="10" Opacity="0.5" Margin="0,0,0,10" />

            <!-- Custom Evaluators -->
            <TextBlock Text="CUSTOM EVALUATORS" FontSize="11" Opacity="0.6" Margin="0,0,0,4" />
            <Button Content="+ Add Custom Evaluator" Click="OnAddCustomEvaluator" Margin="0,0,0,3"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" />
            <TextBlock Text="Define your own evaluation criteria." FontSize="10" Opacity="0.5" Margin="0,0,0,10" />

            <!-- Settings -->
            <TextBlock Text="SETTINGS" FontSize="11" Opacity="0.6" Margin="0,0,0,4" />
            <Button Content="🔑 Set API Key" Click="OnSetApiKey" Margin="0,0,0,3"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" />
            <Button Content="🌐 Open Dashboard" Click="OnOpenDashboard" Margin="0,0,0,3"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" />
            <Button Content="📖 Tutorials" Click="OnOpenDocs" Margin="0,0,0,3"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" />
            <TextBlock Name="ApiKeyStatusText" Text="API key: not set" FontSize="10" Opacity="0.5" Margin="0,0,0,10" />

            <!-- CI/CD -->
            <TextBlock Text="CI/CD" FontSize="11" Opacity="0.6" Margin="0,0,0,4" />
            <Button Content="📋 Generate CI/CD Snippet" Click="OnGenerateCISnippet" Margin="0,0,0,3"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" />
            <TextBlock Text="GitHub Actions / GitLab CI / Jenkins." FontSize="10" Opacity="0.5" Margin="0,0,0,10" />

            <!-- Recent History -->
            <TextBlock Text="RECENT" FontSize="11" Opacity="0.6" Margin="0,0,0,4" />
            <ItemsControl Name="HistoryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource VsBrush.PanelBorder}" BorderThickness="0,0,0,1"
                                Padding="4" Margin="0,2">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="11">
                                    <Run Text="{Binding PassedIcon}" /><Run Text=" " /><Run Text="{Binding Scores}" />
                                </TextBlock>
                                <TextBlock Text="{Binding Query}" FontSize="10" Opacity="0.6"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Name="NoHistoryText" Text="No evaluations yet." FontSize="10" Opacity="0.4" />

            <!-- Status -->
            <TextBlock Name="StatusText" Text="" FontSize="10" Opacity="0.5" Margin="0,10,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
