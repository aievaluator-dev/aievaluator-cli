{
  "name": "aievaluator",
  "displayName": "AI Evaluator",
  "description": "Evaluate your AI agents directly from VS Code",
  "version": "1.0.0",
  "publisher": "aievaluator",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "AI"
  ],
  "activationEvents": [
    "onCommand:aievaluator.evaluateSelection",
    "onCommand:aievaluator.setAPIKey",
    "onCommand:aievaluator.generateCISnippet",
    "onView:aievaluator.sidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aievaluator.evaluateSelection",
        "title": "AI Evaluator: Evaluate selection"
      },
      {
        "command": "aievaluator.setAPIKey",
        "title": "AI Evaluator: Set API Key"
      },
      {
        "command": "aievaluator.generateCISnippet",
        "title": "AI Evaluator: Generate CI/CD Snippet"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aievaluator",
          "title": "AI Evaluator",
          "icon": "$(beaker)"
        }
      ]
    },
    "views": {
      "aievaluator": [
        {
          "id": "aievaluator.sidebar",
          "name": "Evaluations"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "aievaluator.evaluateSelection",
          "group": "aievaluator",
          "when": "editorHasSelection"
        }
      ],
      "commandPalette": [
        {
          "command": "aievaluator.evaluateSelection",
          "when": "editorHasSelection"
        },
        {
          "command": "aievaluator.setAPIKey"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.5"
  }
}
